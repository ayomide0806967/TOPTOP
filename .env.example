NODE_ENV=production
PORT=3000

# Dokploy app public URL.
APP_ORIGIN=https://your-domain.example
BETTER_AUTH_URL=https://your-domain.example
BETTER_AUTH_TRUSTED_ORIGINS=https://your-domain.example
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
BETTER_AUTH_SECURE_COOKIES=true

# Use the service names from docker-compose.dokploy.yml when deploying compose.
DATABASE_URL=postgresql://cbt_fast:replace-db-password@postgres:5432/cbt_fast
REDIS_URL=redis://:replace-redis-password@redis:6379/0
BETTER_AUTH_REDIS_PREFIX=cbt-fast:auth

PAYSTACK_MODE=test
PAYSTACK_PUBLIC_KEY=pk_test_replace
PAYSTACK_SECRET_KEY=sk_test_replace

# Used only by migration scripts on your workstation or VPS shell.
SUPABASE_DB_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres
TARGET_DATABASE_URL=postgresql://cbt_fast:replace-db-password@localhost:5432/cbt_fast
BACKUP_DIR=./backups/supabase
